generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ──────────────────────────────────────────────────────────
// Required by @next-auth/prisma-adapter for user authentication.
// See: https://next-auth.js.org/adapters/prisma

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  hashedPassword String?  // For credentials provider (not in default NextAuth schema)

  accounts      Account[]
  sessions      Session[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── TradeIQ Models ───────────────────────────────────────────────────────────

model Alert {
  id          String   @id @default(cuid())
  userId      String?  // Link to user
  type        String   // "price_target", "confluence", "risk_event", "trade_executed", "position_closed"
  symbol      String   // e.g. "BTC", "AAPL"
  title       String   // Short description
  message     String   // Detailed message
  severity    String   @default("info") // "info", "warning", "critical"
  isRead      Boolean  @default(false)
  isTriggered Boolean  @default(false)
  condition   String   @default("{}") // JSON: { field: "price", operator: ">=", value: 100000 }
  triggeredAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BrokerConfig {
  id           String   @id @default(cuid())
  userId       String?  // Link to user (null = legacy/global config)
  brokerName   String   @default("alpaca")
  apiKey       String   @default("")
  apiSecret    String   @default("")
  isPaper      Boolean  @default(true)
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VectorConfig {
  id          String   @id @default(cuid())
  vectorType  String   // "technical", "pattern", "volume", "news", "sentiment", "macro"
  vectorName  String   // e.g. "rsi", "macd", "doji", "volume_profile"
  isEnabled   Boolean  @default(true)
  weight      Float    @default(1.0)
  settings    String   @default("{}") // JSON string for vector-specific settings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WatchlistItem {
  id        String   @id @default(cuid())
  symbol    String   // e.g. "AAPL", "NVDA"
  name      String   @default("")
  createdAt DateTime @default(now())
}

model Signal {
  id              String   @id @default(cuid())
  userId          String?  // Link to user who created the signal
  symbol          String
  direction       String   // "LONG" or "SHORT"
  entryPrice      Float
  stopLoss        Float
  takeProfit      Float
  riskReward      Float
  confluenceScore Float    // 0-100
  vectorsUsed     String   // JSON array of vector names that contributed
  analysisDetail  String   @default("{}") // JSON with detailed analysis from each vector
  status          String   @default("active") // "active", "executed", "expired", "cancelled"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model JournalEntry {
  id          String   @id @default(cuid())
  userId      String?  // Link to user
  symbol      String
  direction   String   // "LONG" or "SHORT"
  entryPrice  Float
  exitPrice   Float?
  stopLoss    Float
  takeProfit  Float
  result      String?  // "win", "loss", "breakeven", null
  pnl         Float?
  notes       String   @default("")
  lessons     String   @default("")
  vectorsUsed String   @default("[]") // JSON array
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AnalysisCache {
  id        String   @id @default(cuid())
  symbol    String
  type      String   // "technical", "pattern", "volume", "news", "sentiment"
  data      String   // JSON string with analysis results
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
